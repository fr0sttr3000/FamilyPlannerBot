# ============================================================
# FamilyPlannerBot — переменные окружения для тестов
# Скопируйте в .env.test и заполните тестовыми значениями
# НИКОГДА не коммитьте .env.test в git
# ============================================================
BOT_TOKEN=<fake_token_для_тестов>
