# ============================================================
# FamilyPlannerBot — шаблон переменных окружения
# Скопируйте этот файл в .env и заполните реальными значениями
# НИКОГДА не коммитьте .env в git
# ============================================================

# === Telegram ===
# Токен бота, полученный от @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram ID владельца бота (для admin-команд)
OWNER_ID=123456789

# === База данных (PostgreSQL) ===
DB_HOST=db
DB_PORT=5432
DB_NAME=familybot
DB_USER=familybot
DB_PASSWORD=changeme

# === Авторизация ===
# Telegram ID авторизованных пользователей через запятую (без пробелов)
# Как узнать свой ID: напишите @userinfobot в Telegram
ALLOWED_USERS=123456789,987654321

# === Конфигурация ===
# Часовой пояс для отображения дат и напоминаний
TIMEZONE=Europe/Moscow

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Версия приложения (используется как тег Docker-образа; не :latest в prod)
APP_VERSION=v1.0.0
